CompileFlags:
  # Strip GCC‑only or otherwise noisy options that clang can't handle
  CompilationDatabase: build/
  Remove: [
    -fno-printf-return-value,
    -mfp16-format=ieee,
    -fno-reorder-functions,
    -ftrack-macro-expansion=0      # <- the new one
  ]

  # Extra include paths *and* clang's own quiet‑flag
  Add: [
    -Iinclude,
    -Ibuild/zephyr/include/generated,
    -fmacro-backtrace-limit=0,
    -Wno-vla-cxx-extension,
    -std=gnu++2b,
    -xc++,
    # ARM GCC implicit C++ stdlib paths — not in compile_commands.json
    -IC:/FORMULA/Code/VCU/vcu_codebase/zephyr-sdk/zephyr-sdk-0.16.5-1/arm-zephyr-eabi/arm-zephyr-eabi/include/c++/12.2.0,
    -IC:/FORMULA/Code/VCU/vcu_codebase/zephyr-sdk/zephyr-sdk-0.16.5-1/arm-zephyr-eabi/arm-zephyr-eabi/include/c++/12.2.0/arm-zephyr-eabi,
  ]
Diagnostics:
  Suppress: ['-Wunused-includes']