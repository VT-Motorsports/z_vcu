{
    "terminal.integrated.defaultProfile.windows": "Zephyr IDE Terminal",

    // Disable default IntelliSense to avoid conflict
    "editor.semanticHighlighting.enabled": true,


    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.errorSquiggles": "disabled",

    // Still provide compile_commands.json in case anything else looks for it
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",

    // CMake Tools extension behavior
    "cmake.configureOnOpen": false,

    // Clangd configuration
    "clangd.arguments": [
        "--compile-commands-dir=build",
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--pch-storage=memory",
        "--log=error"
    ],
    

    // You may need to set this explicitly if `clangd` is not in PATH:
    // "clangd.path": "C:/path/to/clangd.exe",

    // Optional but recommended — make clangd the default formatter
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true,
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },

    "editor.snippetSuggestions": "inline",

}